AWA_APP_NAME=AI Workflow Automation Assistant
AWA_APP_VERSION=0.1.0
AWA_ENVIRONMENT=local
AWA_DEBUG=true
AWA_LOG_LEVEL=INFO
AWA_API_V1_PREFIX=/api/v1
AWA_DATABASE_URL=sqlite:///./.local/workflow_assistant.db
AWA_PROVIDER_MODE=mock
AWA_OPENAI_API_KEY=
AWA_OPENAI_MODEL=gpt-4.1-mini
AWA_OPENAI_TIMEOUT_SECONDS=30
AWA_OPENAI_FALLBACK_TO_MOCK=false
AWA_OPENAI_PROMPT_VERSION=openai-workflow-v1
AWA_APP_HOST=127.0.0.1
AWA_APP_PORT=8000
